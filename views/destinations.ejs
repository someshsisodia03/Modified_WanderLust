<% layout('boilerplate') -%>

    <body>
        <!-- Search Results Banner -->
        <% if(searchQuery && searchQuery.length > 0){ %>
            <div style="padding: 0.75rem 2.5rem; background:#fff8f8; border-bottom:1px solid #fee2e2; display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--brand);"></i>
                <span style="font-size:0.92rem; font-weight:600; color:var(--dark);">
                    <%= totalDestinations %> result<%= totalDestinations !== 1 ? 's' : '' %> for
                    "<span style="color:var(--brand);"><%= searchQuery %></span>"
                </span>
                <a href="/destinations" style="margin-left:auto; font-size:0.85rem; color:var(--muted); text-decoration:none; display:flex; align-items:center; gap:0.3rem; border:1px solid var(--border); border-radius:50px; padding:0.25rem 0.9rem;">
                    <i class="fa-solid fa-xmark"></i> Clear
                </a>
            </div>
        <% } %>

        <!-- Destinations Grid -->
        <% if(destinations.length === 0) { %>
            <div style="text-align:center; padding:5rem 2rem; color:var(--muted);">
                <i class="fa-solid fa-earth-americas" style="font-size:3rem; margin-bottom:1rem; color:#d1d5db;"></i>
                <% if(searchQuery){ %>
                    <p style="font-size:1.1rem; font-weight:600;">No destinations found for "<%= searchQuery %>"</p>
                    <p style="font-size:0.9rem; margin-bottom:1rem;">Try a different keyword — city name or country</p>
                <% } else { %>
                    <p style="font-size:1.1rem; font-weight:600;">No destinations available</p>
                <% } %>
                <a href="/destinations" class="btn-wl" style="text-decoration:none; margin-top:0.5rem;">View all destinations</a>
            </div>
        <% } else { %>
            <div class="cards" id="dest-grid">
                <% for(let dest of destinations) { %>
                    <a href="/destinations/<%= dest._id %>" class="cardLink pg-card-animated">
                        <div class="card">
                            <div style="overflow:hidden; position:relative;">
                                <% const destImg = (dest.images && dest.images.length > 0 && dest.images[0].url)
                                    ? optimizeImg(dest.images[0].url, 800, 450)
                                    : '/images/aero.png'; %>
                                <img src="<%= destImg %>" class="card-img-top" alt="<%= dest.name %>">
                                <% if(!curruser){ %>
                                    <div style="position:absolute; bottom:0; left:0; right:0; padding:0.5rem 0.75rem; background:linear-gradient(transparent, rgba(0,0,0,0.6)); display:flex; align-items:center; justify-content:flex-end;">
                                        <span style="color:rgba(255,255,255,0.95); font-size:0.78rem; font-weight:500; display:flex; align-items:center; gap:0.35rem;">
                                            <i class="fa-solid fa-lock" style="font-size:0.65rem;"></i> Sign in to explore
                                        </span>
                                    </div>
                                <% } %>
                            </div>
                            <div class="card-body">
                                <div class="card-title-text"><%= dest.name %></div>
                                <div class="card-location">
                                    <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);font-size:0.75rem;"></i>
                                    <%= dest.country %>
                                </div>
                                <div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.5rem; font-size:0.85rem; color:var(--muted);">
                                    <span><i class="fa-solid fa-bed me-1" style="color:var(--brand);"></i><%= dest.stayCount %> Stay<%= dest.stayCount !== 1 ? 's' : '' %></span>
                                    <span><i class="fa-solid fa-person-hiking me-1" style="color:var(--brand);"></i><%= dest.expCount %> Experience<%= dest.expCount !== 1 ? 's' : '' %></span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% } %>
            </div>

            <!-- Load More Button -->
            <% if(totalDestinations > perPage) { %>
                <div class="pg-load-more-wrap" id="dest-load-more-wrap">
                    <button class="pg-load-more-btn" id="dest-load-more" onclick="loadMoreDestinations()">
                        <i class="fa-solid fa-chevron-down"></i>
                        Load More Destinations
                        <span class="pg-load-count">(<%= destinations.length %> of <%= totalDestinations %>)</span>
                    </button>
                </div>
            <% } %>
        <% } %>

        <style>
            .pg-card-animated{opacity:0;transform:translateY(24px);animation:pgFadeIn .5s ease forwards}
            .pg-card-animated:nth-child(1){animation-delay:.05s}.pg-card-animated:nth-child(2){animation-delay:.1s}
            .pg-card-animated:nth-child(3){animation-delay:.15s}.pg-card-animated:nth-child(4){animation-delay:.2s}
            .pg-card-animated:nth-child(5){animation-delay:.25s}.pg-card-animated:nth-child(6){animation-delay:.3s}
            @keyframes pgFadeIn{to{opacity:1;transform:translateY(0)}}
            .pg-skel{border-radius:16px;overflow:hidden;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.06);border:1px solid #f0f0f0}
            .pg-skel-img{width:100%;height:200px;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:pgShimmer 1.5s ease-in-out infinite}
            .pg-skel-body{padding:1rem}.pg-skel-line{height:14px;border-radius:6px;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:pgShimmer 1.5s ease-in-out infinite;margin-bottom:.6rem}
            .pg-skel-line.w75{width:75%}.pg-skel-line.w50{width:50%}.pg-skel-line.w30{width:30%}
            @keyframes pgShimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
            .pg-load-more-wrap{text-align:center;margin:2rem 0 1rem}
            .pg-load-more-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 2rem;border:2px solid var(--border);border-radius:50px;background:#fff;color:var(--dark);font-family:'Inter',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:all .3s ease}
            .pg-load-more-btn:hover{border-color:var(--brand);color:var(--brand);transform:translateY(-2px);box-shadow:0 6px 20px rgba(254,66,77,.15)}
            .pg-load-more-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
            .pg-load-more-btn i{transition:transform .3s ease}.pg-load-more-btn:hover i{transform:translateY(3px)}
            .pg-load-count{font-size:.78rem;color:var(--muted);font-weight:500}
            .pg-load-more-btn.loading i{animation:pgSpin .8s linear infinite}
            @keyframes pgSpin{to{transform:rotate(360deg)}}
        </style>

        <script>
            const destPerPage = <%= perPage %>;
            const totalDest = <%= totalDestinations %>;
            const destSearchQ = '<%= searchQuery %>';
            const isLoggedIn = <% if(curruser) { %>true<% } else { %>false<% } %>;
            let destPage = 1;
            let destLoading = false;

            function optimizeImgUrl(url, w, h) {
                w = w || 800; h = h || 450;
                if (!url) return url;
                if (url.includes('res.cloudinary.com') && url.includes('/upload/')) {
                    return url.replace('/upload/', '/upload/w_' + w + ',h_' + h + ',c_fill,g_auto,q_auto:best,f_auto/');
                }
                return url;
            }

            function createSkeleton() {
                return '<div class="pg-skel"><div class="pg-skel-img"></div><div class="pg-skel-body"><div class="pg-skel-line w75"></div><div class="pg-skel-line w50"></div><div class="pg-skel-line w30"></div></div></div>';
            }

            async function loadMoreDestinations() {
                if (destLoading) return;
                destLoading = true;
                const btn = document.getElementById('dest-load-more');
                btn.classList.add('loading');
                btn.querySelector('i').className = 'fa-solid fa-spinner';
                btn.disabled = true;

                const grid = document.getElementById('dest-grid');
                const skelWrap = document.createElement('div');
                skelWrap.style.display = 'contents';
                for (let i = 0; i < Math.min(destPerPage, 3); i++) {
                    const d = document.createElement('div'); d.style.display = 'contents';
                    d.innerHTML = createSkeleton(); skelWrap.appendChild(d);
                }
                grid.appendChild(skelWrap);
                await new Promise(r => setTimeout(r, 600));

                try {
                    const nextPage = destPage + 1;
                    let url = '/destinations/api/paginate?page=' + nextPage;
                    if (destSearchQ) url += '&search=' + encodeURIComponent(destSearchQ);
                    const res = await fetch(url);
                    const data = await res.json();
                    if (skelWrap.parentNode) skelWrap.parentNode.removeChild(skelWrap);

                    data.items.forEach((item, i) => {
                        const imgUrl = (item.images && item.images.length > 0 && item.images[0].url)
                            ? optimizeImgUrl(item.images[0].url) : '/images/aero.png';
                        const lockBadge = !isLoggedIn ? `<div style="position:absolute; bottom:0; left:0; right:0; padding:0.5rem 0.75rem; background:linear-gradient(transparent, rgba(0,0,0,0.6)); display:flex; align-items:center; justify-content:flex-end;">
                            <span style="color:rgba(255,255,255,0.95); font-size:0.78rem; font-weight:500; display:flex; align-items:center; gap:0.35rem;">
                                <i class="fa-solid fa-lock" style="font-size:0.65rem;"></i> Sign in to explore
                            </span></div>` : '';
                        const html = `<a href="/destinations/${item._id}" class="cardLink pg-card-animated" style="animation-delay:${i*0.08}s;">
                            <div class="card">
                                <div style="overflow:hidden; position:relative;">
                                    <img src="${imgUrl}" class="card-img-top" alt="${item.name}">
                                    ${lockBadge}
                                </div>
                                <div class="card-body">
                                    <div class="card-title-text">${item.name}</div>
                                    <div class="card-location">
                                        <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);font-size:0.75rem;"></i>
                                        ${item.country}
                                    </div>
                                    <div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.5rem; font-size:0.85rem; color:var(--muted);">
                                        <span><i class="fa-solid fa-bed me-1" style="color:var(--brand);"></i>${item.stayCount} Stay${item.stayCount !== 1 ? 's' : ''}</span>
                                        <span><i class="fa-solid fa-person-hiking me-1" style="color:var(--brand);"></i>${item.expCount} Experience${item.expCount !== 1 ? 's' : ''}</span>
                                    </div>
                                </div>
                            </div>
                        </a>`;
                        const t = document.createElement('div'); t.innerHTML = html;
                        grid.appendChild(t.firstElementChild);
                    });

                    destPage = nextPage;
                    const loaded = Math.min(destPage * destPerPage, totalDest);
                    btn.querySelector('.pg-load-count').textContent = '(' + loaded + ' of ' + totalDest + ')';

                    if (!data.hasMore) {
                        document.getElementById('dest-load-more-wrap').style.display = 'none';
                    } else {
                        btn.classList.remove('loading');
                        btn.querySelector('i').className = 'fa-solid fa-chevron-down';
                        btn.disabled = false;
                    }
                } catch(e) {
                    console.error(e);
                    if (skelWrap.parentNode) skelWrap.parentNode.removeChild(skelWrap);
                    btn.classList.remove('loading');
                    btn.querySelector('i').className = 'fa-solid fa-chevron-down';
                    btn.disabled = false;
                }
                destLoading = false;
            }
        </script>
    </body>
