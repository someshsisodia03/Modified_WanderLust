<% layout('boilerplate') -%>

    <body>
        <!-- Search Results Banner -->
        <% if(searchQuery && searchQuery.length > 0){ %>
            <div style="padding: 0.75rem 2.5rem; background:#fff8f8; border-bottom:1px solid #fee2e2; display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--brand);"></i>
                <span style="font-size:0.92rem; font-weight:600; color:var(--dark);">
                    <%= destinations.length %> result<%= destinations.length !== 1 ? 's' : '' %> for
                    "<span style="color:var(--brand);"><%= searchQuery %></span>"
                </span>
                <a href="/destinations" style="margin-left:auto; font-size:0.85rem; color:var(--muted); text-decoration:none; display:flex; align-items:center; gap:0.3rem; border:1px solid var(--border); border-radius:50px; padding:0.25rem 0.9rem;">
                    <i class="fa-solid fa-xmark"></i> Clear
                </a>
            </div>
        <% } %>

        <!-- Destinations Grid -->
        <% if(destinations.length === 0) { %>
            <div style="text-align:center; padding:5rem 2rem; color:var(--muted);">
                <i class="fa-solid fa-earth-americas" style="font-size:3rem; margin-bottom:1rem; color:#d1d5db;"></i>
                <% if(searchQuery){ %>
                    <p style="font-size:1.1rem; font-weight:600;">No destinations found for "<%= searchQuery %>"</p>
                    <p style="font-size:0.9rem; margin-bottom:1rem;">Try a different keyword — city name or country</p>
                <% } else { %>
                    <p style="font-size:1.1rem; font-weight:600;">No destinations available</p>
                <% } %>
                <a href="/destinations" class="btn-wl" style="text-decoration:none; margin-top:0.5rem;">View all destinations</a>
            </div>
        <% } else { %>
            <div class="cards">
                <% for(let dest of destinations) { %>
                    <a href="/destinations/<%= dest._id %>" class="cardLink">
                        <div class="card">
                            <div style="overflow:hidden; position:relative;">
                                <% const destImg = (dest.images && dest.images.length > 0 && dest.images[0].url)
                                    ? optimizeImg(dest.images[0].url, 800, 450)
                                    : '/images/aero.png'; %>
                                <img src="<%= destImg %>" class="card-img-top" alt="<%= dest.name %>">
                                <% if(!curruser){ %>
                                    <div style="position:absolute; bottom:0; left:0; right:0; padding:0.5rem 0.75rem; background:linear-gradient(transparent, rgba(0,0,0,0.6)); display:flex; align-items:center; justify-content:flex-end;">
                                        <span style="color:rgba(255,255,255,0.95); font-size:0.78rem; font-weight:500; display:flex; align-items:center; gap:0.35rem;">
                                            <i class="fa-solid fa-lock" style="font-size:0.65rem;"></i> Sign in to explore
                                        </span>
                                    </div>
                                <% } %>
                            </div>
                            <div class="card-body">
                                <div class="card-title-text"><%= dest.name %></div>
                                <div class="card-location">
                                    <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);font-size:0.75rem;"></i>
                                    <%= dest.country %>
                                </div>
                                <div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.5rem; font-size:0.85rem; color:var(--muted);">
                                    <span><i class="fa-solid fa-bed me-1" style="color:var(--brand);"></i><%= dest.stayCount %> Stay<%= dest.stayCount !== 1 ? 's' : '' %></span>
                                    <span><i class="fa-solid fa-person-hiking me-1" style="color:var(--brand);"></i><%= dest.expCount %> Experience<%= dest.expCount !== 1 ? 's' : '' %></span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% } %>
            </div>
        <% } %>
    </body>
