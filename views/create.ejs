<% layout('boilerplate') -%>

    <body>
        <div class="forms" style="padding: 2.5rem 1rem;">
            <div class="wl-form-card" style="max-width:640px;">
                <div class="wl-form-title">✈️ Add a New Listing</div>
                <div class="wl-form-subtitle">Share your amazing place with travellers around the world</div>

                <form class="needs-validation" method="POST" action="/addDetail" novalidate
                    enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" class="form-control" id="title" placeholder="Give your place a catchy title"
                            name="title" required>
                        <div class="valid-feedback">Looks great!</div>
                    </div>
                    <div class="mb-3">
                        <label for="desc" class="form-label">Description</label>
                        <textarea class="form-control" id="desc" name="description" rows="3"
                            placeholder="Describe your listing — what makes it special?" required></textarea>
                        <div class="invalid-feedback">Please fill in the description.</div>
                    </div>
                    <div class="mb-3">
                        <label for="url" class="form-label">Upload Image</label>
                        <input type="file" class="form-control" id="url" name="url" accept="image/*" required>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="price" class="form-label">Price per Night (₹)</label>
                            <input type="number" class="form-control" id="price" placeholder="e.g. 2500" name="price"
                                min="0" required>
                            <div class="invalid-feedback">Please enter a valid price.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" class="form-control" id="country" name="country" placeholder="e.g. India"
                                required>
                            <div class="invalid-feedback">Please enter a country.</div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="category" class="form-label">Category
                            <span id="ai-cat-badge" style="display:none; margin-left:0.5rem; font-size:0.62rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:50px; background:#eef2ff; color:#6366f1; vertical-align:middle;">
                                <i class="fa-solid fa-robot" style="font-size:0.55rem;"></i> AI-Assisted
                            </span>
                        </label>
                        <select class="form-control" id="category" name="category" required>
                            <option value="">Select a category</option>
                            <option value="Trending">🔥 Trending</option>
                            <option value="Rooms">🛏️ Rooms</option>
                            <option value="Iconic Cities">🌆 Iconic Cities</option>
                            <option value="Mountains">⛰️ Mountains</option>
                            <option value="Castles">🏰 Castles</option>
                            <option value="Beaches">🏖️ Beaches</option>
                            <option value="Camping">⛺ Camping</option>
                            <option value="Farms">🚜 Farms</option>
                            <option value="Arctic">❄️ Arctic</option>
                        </select>
                        <div class="invalid-feedback">Please select a category.</div>

                        <!-- AI Prediction Panel -->
                        <div id="ai-predict-panel" style="display:none; margin-top:0.6rem; padding:0.75rem 0.85rem; background:linear-gradient(135deg,#fafbff,#f0f4ff); border-radius:12px; border:1px solid #e0e7ff;">
                            <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.5rem;">
                                <i class="fa-solid fa-robot" style="color:#6366f1; font-size:0.75rem;"></i>
                                <span style="font-size:0.72rem; font-weight:700; color:#6366f1; text-transform:uppercase; letter-spacing:0.05em;">Naive Bayes Prediction</span>
                                <span id="ai-predict-loading" style="display:none;"><i class="fa-solid fa-spinner fa-spin" style="font-size:0.7rem; color:#6366f1;"></i></span>
                            </div>
                            <div id="ai-predict-results"></div>
                            <button type="button" id="ai-accept-btn" style="display:none; margin-top:0.5rem; font-size:0.7rem; font-weight:600; color:white; background:linear-gradient(135deg,#6366f1,#8b5cf6); border:none; border-radius:50px; padding:0.3rem 0.8rem; cursor:pointer; transition:all 0.2s;">
                                <i class="fa-solid fa-check"></i> Accept AI Suggestion
                            </button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" class="form-control" id="location" name="location"
                            placeholder="e.g. Jaipur, Rajasthan" required>
                        <div class="invalid-feedback">Please enter a location.</div>
                    </div>

                    <!-- ── Optional Experience Section ── -->
                    <div class="exp-toggle-wrap mb-3" style="
                        border: 1.5px solid var(--border);
                        border-radius: 14px;
                        overflow: hidden;
                        transition: border-color 0.3s ease;
                    ">
                        <label for="addExpToggle" class="exp-toggle-header" style="
                            display: flex; align-items: center; gap: 0.75rem;
                            padding: 0.85rem 1.1rem; cursor: pointer;
                            background: #f9fafb; margin: 0;
                            font-weight: 600; font-size: 0.95rem; color: var(--dark);
                            transition: background 0.25s ease;
                        ">
                            <input type="checkbox" id="addExpToggle" name="addExperience" value="yes" style="
                                accent-color: var(--brand); width: 18px; height: 18px; cursor: pointer;
                            ">
                            <span style="flex:1;">🎯 Also add an Experience <span style="
                                font-weight: 400; font-size: 0.82rem; color: var(--muted);
                            ">(optional)</span></span>
                            <i class="fa-solid fa-chevron-down exp-chevron" style="
                                font-size: 0.75rem; color: var(--muted);
                                transition: transform 0.3s ease;
                            "></i>
                        </label>

                        <div id="expFields" style="
                            max-height: 0; overflow: hidden;
                            transition: max-height 0.4s ease, padding 0.3s ease;
                            padding: 0 1.1rem;
                        ">
                            <div style="padding-top: 0.75rem; padding-bottom: 1rem;">
                                <div class="mb-3">
                                    <label for="expTitle" class="form-label">Experience Title</label>
                                    <input type="text" class="form-control" id="expTitle" name="expTitle"
                                        placeholder="e.g. Sunset Camel Safari">
                                </div>
                                <div class="mb-3">
                                    <label for="expDesc" class="form-label">Experience Description</label>
                                    <textarea class="form-control" id="expDesc" name="expDescription" rows="2"
                                        placeholder="Describe the experience — what will travellers do?"></textarea>
                                </div>
                                <div class="mb-3">
                                    <label for="expImage" class="form-label">Experience Image</label>
                                    <input type="file" class="form-control" id="expImage" name="expImage" accept="image/*">
                                    <div style="font-size:0.78rem; color:var(--muted); margin-top:0.25rem;">
                                        Leave empty to use the listing image
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="expCategory" class="form-label">Category
                                        <span id="exp-ai-badge" style="display:none; margin-left:0.5rem; font-size:0.62rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:50px; background:#fef3c7; color:#d97706; vertical-align:middle;">
                                            <i class="fa-solid fa-robot" style="font-size:0.55rem;"></i> AI-Assisted
                                        </span>
                                    </label>
                                    <select class="form-control" id="expCategory" name="expCategory">
                                        <option value="">Same as listing</option>
                                        <option value="Trending">🔥 Trending</option>
                                        <option value="Rooms">🛏️ Rooms</option>
                                        <option value="Iconic Cities">🌆 Iconic Cities</option>
                                        <option value="Mountains">⛰️ Mountains</option>
                                        <option value="Castles">🏰 Castles</option>
                                        <option value="Beaches">🏖️ Beaches</option>
                                        <option value="Camping">⛺ Camping</option>
                                        <option value="Farms">🚜 Farms</option>
                                        <option value="Arctic">❄️ Arctic</option>
                                    </select>

                                    <!-- Experience AI Prediction Panel -->
                                    <div id="exp-ai-panel" style="display:none; margin-top:0.6rem; padding:0.75rem 0.85rem; background:linear-gradient(135deg,#fffdf5,#fef9e7); border-radius:12px; border:1px solid #fde68a;">
                                        <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.5rem;">
                                            <i class="fa-solid fa-robot" style="color:#d97706; font-size:0.75rem;"></i>
                                            <span style="font-size:0.72rem; font-weight:700; color:#d97706; text-transform:uppercase; letter-spacing:0.05em;">Experience Prediction</span>
                                            <span id="exp-ai-loading" style="display:none;"><i class="fa-solid fa-spinner fa-spin" style="font-size:0.7rem; color:#d97706;"></i></span>
                                        </div>
                                        <div id="exp-ai-results"></div>
                                        <button type="button" id="exp-ai-accept" style="display:none; margin-top:0.5rem; font-size:0.7rem; font-weight:600; color:white; background:linear-gradient(135deg,#d97706,#f59e0b); border:none; border-radius:50px; padding:0.3rem 0.8rem; cursor:pointer; transition:all 0.2s;">
                                            <i class="fa-solid fa-check"></i> Accept
                                        </button>
                                    </div>
                                </div>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label for="expDuration" class="form-label">Duration</label>
                                        <input type="text" class="form-control" id="expDuration" name="expDuration"
                                            placeholder="e.g. 3 hours">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="expDifficulty" class="form-label">Difficulty</label>
                                        <select class="form-control" id="expDifficulty" name="expDifficulty">
                                            <option value="Easy">🟢 Easy</option>
                                            <option value="Moderate">🟡 Moderate</option>
                                            <option value="Challenging">🟠 Challenging</option>
                                            <option value="Extreme">🔴 Extreme</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="expPrice" class="form-label">Price (₹/person)</label>
                                        <input type="number" class="form-control" id="expPrice" name="expPrice"
                                            placeholder="e.g. 1500" min="0">
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn-wl w-100" style="justify-content:center;">
                        <i class="fa-solid fa-plus"></i> Create Listing
                    </button>
                </form>

                <!-- Upload Loading Overlay -->
                <div id="uploadOverlay" style="
                    display:none; position:fixed; inset:0; z-index:9999;
                    background:rgba(0,0,0,0.6); backdrop-filter:blur(4px);
                    flex-direction:column; align-items:center; justify-content:center; gap:1.25rem;
                ">
                    <div style="
                        background:white; border-radius:20px; padding:2.5rem 3rem;
                        text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);
                        max-width:340px; width:90%;
                    ">
                        <div class="upload-spinner" style="
                            width:48px; height:48px; border:4px solid #f1f5f9;
                            border-top-color:var(--brand); border-radius:50%;
                            animation:spin 0.8s linear infinite; margin:0 auto 1.25rem;
                        "></div>
                        <div style="font-weight:700; font-size:1.1rem; color:var(--dark); margin-bottom:0.4rem;">
                            Uploading your listing...
                        </div>
                        <div id="uploadStatus" style="font-size:0.85rem; color:var(--muted);">
                            Sending image to cloud ☁️
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            @keyframes spin { to { transform: rotate(360deg); } }
        </style>

        <!-- Client-side image compression library -->
        <script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.js"></script>

        <script>
            // Toggle experience fields
            const toggle = document.getElementById('addExpToggle');
            const expFields = document.getElementById('expFields');
            const chevron = document.querySelector('.exp-chevron');
            const wrap = document.querySelector('.exp-toggle-wrap');

            toggle.addEventListener('change', () => {
                if (toggle.checked) {
                    expFields.style.maxHeight = expFields.scrollHeight + 'px';
                    expFields.style.padding = '0 1.1rem';
                    chevron.style.transform = 'rotate(180deg)';
                    wrap.style.borderColor = 'var(--brand)';
                } else {
                    expFields.style.maxHeight = '0';
                    chevron.style.transform = 'rotate(0)';
                    wrap.style.borderColor = 'var(--border)';
                }
            });

            // Compress + upload with loading overlay
            const form = document.querySelector('form.needs-validation');
            const overlay = document.getElementById('uploadOverlay');
            const submitBtn = document.getElementById('submitBtn');
            const statusText = document.getElementById('uploadStatus');

            const compressionOptions = {
                maxSizeMB: 1,            // Max 1MB output
                maxWidthOrHeight: 1920,   // Max 1920px — plenty for 1600×900 display
                useWebWorker: true,
                initialQuality: 0.9       // 90% quality — visually identical
            };

            const messages = [
                'Uploading to cloud ☁️',
                'Optimizing your listing ✨',
                'Almost there... 🚀',
                'Setting up your destination 🗺️',
                'Just a moment more... ⏳'
            ];

            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                if (!form.checkValidity()) {
                    form.classList.add('was-validated');
                    return;
                }

                // Show overlay
                overlay.style.display = 'flex';
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Compressing...';

                try {
                    // Compress listing image
                    const listingInput = document.getElementById('url');
                    if (listingInput.files && listingInput.files[0]) {
                        const original = listingInput.files[0];
                        statusText.textContent = 'Compressing listing image... 🗜️';

                        const compressed = await imageCompression(original, compressionOptions);
                        const compressedFile = new File([compressed], original.name, { type: compressed.type });

                        // Replace file input with compressed file
                        const dt = new DataTransfer();
                        dt.items.add(compressedFile);
                        listingInput.files = dt.files;

                        const saved = ((original.size - compressed.size) / original.size * 100).toFixed(0);
                        console.log(`Listing image: ${(original.size/1024/1024).toFixed(1)}MB → ${(compressed.size/1024/1024).toFixed(1)}MB (${saved}% smaller)`);
                    }

                    // Compress experience image (if provided)
                    const expInput = document.getElementById('expImage');
                    if (expInput && expInput.files && expInput.files[0]) {
                        statusText.textContent = 'Compressing experience image... 🗜️';
                        const original = expInput.files[0];
                        const compressed = await imageCompression(original, compressionOptions);
                        const compressedFile = new File([compressed], original.name, { type: compressed.type });
                        const dt = new DataTransfer();
                        dt.items.add(compressedFile);
                        expInput.files = dt.files;
                    }

                    // Now submit
                    statusText.textContent = 'Uploading to cloud ☁️';
                    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Uploading...';

                    // Cycle through messages
                    let i = 0;
                    setInterval(() => {
                        i = (i + 1) % messages.length;
                        statusText.textContent = messages[i];
                    }, 2500);

                    form.submit();

                } catch (err) {
                    console.error('Compression failed, submitting original:', err);
                    statusText.textContent = 'Uploading original image ☁️';
                    form.submit();
                }
            });
        </script>

        <!-- ── AI Category Prediction Script (Naive Bayes) ── -->
        <script>
        (function() {
            // ── Shared config ──
            var catIcons = {
                'Trending': '🔥', 'Rooms': '🛏️', 'Iconic Cities': '🌆',
                'Mountains': '⛰️', 'Castles': '🏰', 'Beaches': '🏖️',
                'Camping': '⛺', 'Farms': '🚜', 'Arctic': '❄️'
            };
            var barColors = ['#6366f1', '#8b5cf6', '#a78bfa'];

            /**
             * Creates an independent AI predictor for a section.
             * Each section (listing / experience) gets its own predictor
             * that watches its own title + description fields.
             */
            function createPredictor(config) {
                var titleEl = document.getElementById(config.titleId);
                var descEl = document.getElementById(config.descId);
                var selectEl = document.getElementById(config.selectId);
                var panel = document.getElementById(config.panelId);
                var resultsDiv = document.getElementById(config.resultsId);
                var loadingEl = document.getElementById(config.loadingId);
                var acceptBtn = document.getElementById(config.acceptId);
                var badge = document.getElementById(config.badgeId);
                var accentColor = config.accentColor || '#6366f1';
                var timer = null;
                var topPred = null;

                if (!titleEl || !descEl || !selectEl || !panel) return;

                function buildBars(predictions) {
                    var html = '';
                    var top3 = predictions.slice(0, 3);
                    for (var i = 0; i < top3.length; i++) {
                        var p = top3[i];
                        var icon = catIcons[p.category] || '📂';
                        var color = barColors[i];
                        var isTop = i === 0;
                        html += '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:' + (i < top3.length - 1 ? '0.4rem' : '0') + ';">' +
                            '<span style="font-size:0.8rem;min-width:20px;">' + icon + '</span>' +
                            '<div style="flex:1;min-width:0;">' +
                                '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;">' +
                                    '<span style="font-size:0.72rem;font-weight:' + (isTop ? '700' : '500') + ';color:' + (isTop ? '#1e1b4b' : '#6b7280') + ';">' + p.category + '</span>' +
                                    '<span style="font-size:0.68rem;font-weight:700;color:' + color + ';">' + p.confidence + '%</span>' +
                                '</div>' +
                                '<div style="height:5px;background:#e8eaff;border-radius:50px;overflow:hidden;">' +
                                    '<div style="height:100%;border-radius:50px;background:' + color + ';width:0%;transition:width 0.6s ease;" class="ai-bar-' + config.id + '" data-w="' + p.confidence + '"></div>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                    }
                    return html;
                }

                function predict() {
                    var text = (titleEl.value + ' ' + descEl.value).trim();
                    if (text.length < 8) {
                        panel.style.display = 'none';
                        return;
                    }

                    panel.style.display = 'block';
                    if (badge) badge.style.display = 'inline';
                    loadingEl.style.display = 'inline';

                    clearTimeout(timer);
                    timer = setTimeout(function() {
                        fetch('/api/ml/predict', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ text: text })
                        })
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            loadingEl.style.display = 'none';
                            if (!data.predictions || data.predictions.length === 0) {
                                resultsDiv.innerHTML = '<div style="font-size:0.75rem;color:#9ca3af;">Not enough data</div>';
                                return;
                            }
                            topPred = data.predictions[0].category;
                            resultsDiv.innerHTML = buildBars(data.predictions);

                            // Animate bars
                            setTimeout(function() {
                                var bars = resultsDiv.querySelectorAll('.ai-bar-' + config.id);
                                bars.forEach(function(b) { b.style.width = b.getAttribute('data-w') + '%'; });
                            }, 50);

                            // Show accept button
                            if (data.predictions[0].confidence >= 30) {
                                acceptBtn.style.display = 'inline-block';
                                acceptBtn.textContent = '✓ Use "' + topPred + '"';
                            } else {
                                acceptBtn.style.display = 'none';
                            }
                        })
                        .catch(function() {
                            loadingEl.style.display = 'none';
                            resultsDiv.innerHTML = '<div style="font-size:0.75rem;color:#9ca3af;">Prediction unavailable</div>';
                        });
                    }, 600);
                }

                // Listen on title and description
                titleEl.addEventListener('input', predict);
                descEl.addEventListener('input', predict);

                // Accept button
                acceptBtn.addEventListener('click', function() {
                    if (topPred) {
                        selectEl.value = topPred;
                        selectEl.style.transition = 'box-shadow 0.3s ease';
                        selectEl.style.boxShadow = '0 0 0 3px ' + accentColor + '40';
                        setTimeout(function() { selectEl.style.boxShadow = 'none'; }, 1500);
                        acceptBtn.textContent = '✓ Applied!';
                        acceptBtn.style.background = 'linear-gradient(135deg,#059669,#10b981)';
                        setTimeout(function() {
                            acceptBtn.style.display = 'none';
                            acceptBtn.style.background = config.btnGradient;
                        }, 1500);
                    }
                });
            }

            // ── Predictor 1: LISTING category (from listing title + description) ──
            createPredictor({
                id: 'listing',
                titleId: 'title',
                descId: 'desc',
                selectId: 'category',
                panelId: 'ai-predict-panel',
                resultsId: 'ai-predict-results',
                loadingId: 'ai-predict-loading',
                acceptId: 'ai-accept-btn',
                badgeId: 'ai-cat-badge',
                accentColor: '#6366f1',
                btnGradient: 'linear-gradient(135deg,#6366f1,#8b5cf6)'
            });

            // ── Predictor 2: EXPERIENCE category (from experience title + description) ──
            createPredictor({
                id: 'experience',
                titleId: 'expTitle',
                descId: 'expDesc',
                selectId: 'expCategory',
                panelId: 'exp-ai-panel',
                resultsId: 'exp-ai-results',
                loadingId: 'exp-ai-loading',
                acceptId: 'exp-ai-accept',
                badgeId: 'exp-ai-badge',
                accentColor: '#d97706',
                btnGradient: 'linear-gradient(135deg,#d97706,#f59e0b)'
            });
        })();
        </script>
    </body>
