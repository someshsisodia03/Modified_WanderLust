<% layout('boilerplate') -%>

    <body>
        <!-- Category Filters -->
        <div class="filters-wrap">
        <button class="filter-arrow filter-arrow-left hidden" aria-label="Scroll left"><i class="fa-solid fa-chevron-left"></i></button>
        <button class="filter-arrow filter-arrow-right" aria-label="Scroll right"><i class="fa-solid fa-chevron-right"></i></button>
        <div class="filters">
            <div class="filter <% if(activeCategory==='Trending') { %>active<% } %>">
                <a href="/experiences/filter/Trending"><i class="fa-solid fa-fire"></i><p class="icon-text">Trending</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Rooms') { %>active<% } %>">
                <a href="/experiences/filter/Rooms"><i class="fa-solid fa-bed"></i><p class="icon-text">Rooms</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Iconic Cities') { %>active<% } %>">
                <a href="/experiences/filter/Iconic Cities"><i class="fa-solid fa-mountain-city"></i><p class="icon-text">Iconic Cities</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Mountains') { %>active<% } %>">
                <a href="/experiences/filter/Mountains"><i class="fa-solid fa-mountain"></i><p class="icon-text">Mountains</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Castles') { %>active<% } %>">
                <a href="/experiences/filter/Castles"><i class="fa-brands fa-fort-awesome"></i><p class="icon-text">Castles</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Beaches') { %>active<% } %>">
                <a href="/experiences/filter/Beaches"><i class="fa-solid fa-person-swimming"></i><p class="icon-text">Beaches</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Camping') { %>active<% } %>">
                <a href="/experiences/filter/Camping"><i class="fa-solid fa-campground"></i><p class="icon-text">Camping</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Farms') { %>active<% } %>">
                <a href="/experiences/filter/Farms"><i class="fa-solid fa-tractor"></i><p class="icon-text">Farms</p></a>
            </div>
            <div class="filter <% if(activeCategory==='Arctic') { %>active<% } %>">
                <a href="/experiences/filter/Arctic"><i class="fa-regular fa-snowflake"></i><p class="icon-text">Arctic</p></a>
            </div>
            <a href="/experiences" class="tax-box ms-auto" style="text-decoration:none; color:var(--text);">
                <i class="fa-solid fa-arrow-left" style="color:var(--brand);"></i> All experiences
            </a>
        </div>
        </div>


        <!-- Search Results Banner -->
        <% if(typeof searchQuery !== 'undefined' && searchQuery && searchQuery.length > 0){ %>
            <div style="padding: 0.75rem 2.5rem; background:#fff8f8; border-bottom:1px solid #fee2e2; display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--brand);"></i>
                <span style="font-size:0.92rem; font-weight:600; color:var(--dark);">
                    <%= totalExperiences %> result<%= totalExperiences !== 1 ? 's' : '' %> for
                    "<span style="color:var(--brand);"><%= searchQuery %></span>"
                </span>
                <a href="/experiences" style="margin-left:auto; font-size:0.85rem; color:var(--muted); text-decoration:none; display:flex; align-items:center; gap:0.3rem; border:1px solid var(--border); border-radius:50px; padding:0.25rem 0.9rem;">
                    <i class="fa-solid fa-xmark"></i> Clear
                </a>
            </div>
        <% } %>

        <!-- Experience Cards -->
        <% if(experiences.length === 0) { %>
            <div style="text-align:center; padding:5rem 2rem; color:var(--muted);">
                <i class="fa-solid fa-mountain-sun" style="font-size:3rem; margin-bottom:1rem; color:#d1d5db;"></i>
                <% if(typeof searchQuery !== 'undefined' && searchQuery){ %>
                    <p style="font-size:1.1rem; font-weight:600;">No experiences found for "<%= searchQuery %>"</p>
                    <p style="font-size:0.9rem; margin-bottom:1rem;">Try a different keyword</p>
                    <a href="/experiences" class="btn-wl" style="text-decoration:none;">Clear Search</a>
                <% } else if(activeCategory) { %>
                    <p style="font-size:1.1rem; font-weight:600;">No experiences found in "<%= activeCategory %>"</p>
                    <a href="/experiences" class="btn-wl" style="text-decoration:none; margin-top:0.5rem;">View all experiences</a>
                <% } else { %>
                    <p style="font-size:1.1rem; font-weight:600;">No experiences available yet</p>
                <% } %>
            </div>
        <% } else { %>
            <div class="cards" id="exp-grid">
                <% for(let exp of experiences) { %>
                    <a href="/experiences/<%= exp._id %>?from=experiences" class="cardLink pg-card-animated">
                        <div class="card">
                            <div style="overflow:hidden; position:relative;">
                                <% const rawUrl = (exp.images && exp.images.length > 0 && exp.images[0].url && exp.images[0].url.trim().length > 0)
                                    ? exp.images[0].url.trim() : '';
                                   const expImg = rawUrl ? optimizeImg(rawUrl, 800, 450) : '/images/default-experience.png'; %>
                                <img src="<%= expImg %>" class="card-img-top" alt="<%= exp.title %>"
                                     onerror="this.onerror=null; this.src='/images/default-experience.png';">
                                <!-- Difficulty badge -->
                                <span style="position:absolute; top:0.6rem; right:0.6rem; font-size:0.7rem; font-weight:700;
                                    text-transform:uppercase; letter-spacing:0.5px; padding:0.2rem 0.65rem; border-radius:50px;
                                    background:<%= exp.difficulty === 'Easy' ? '#ecfdf5' : exp.difficulty === 'Moderate' ? '#fff7ed' : exp.difficulty === 'Challenging' ? '#fef2f2' : '#faf5ff' %>;
                                    color:<%= exp.difficulty === 'Easy' ? '#059669' : exp.difficulty === 'Moderate' ? '#d97706' : exp.difficulty === 'Challenging' ? '#dc2626' : '#7c3aed' %>;">
                                    <%= exp.difficulty %>
                                </span>
                            </div>
                            <div class="card-body">
                                <div class="card-title-text"><%= exp.title %></div>
                                <div class="card-location">
                                    <% if(exp.destination) { %>
                                        <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);font-size:0.75rem;"></i>
                                        <%= exp.destination.name %>, <%= exp.destination.country %>
                                    <% } %>
                                </div>
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.4rem;">
                                    <div class="card-price">
                                        &#8377; <%= exp.price.toLocaleString("en-IN") %>
                                        <span>/person</span>
                                    </div>
                                    <span style="font-size:0.75rem; color:var(--muted);">
                                        <i class="fa-regular fa-clock me-1"></i><%= exp.duration %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% } %>
            </div>

            <!-- Load More Button -->
            <% if(totalExperiences > perPage) { %>
                <div class="pg-load-more-wrap" id="exp-load-more-wrap">
                    <button class="pg-load-more-btn" id="exp-load-more" onclick="loadMoreExperiences()">
                        <i class="fa-solid fa-chevron-down"></i>
                        Load More Experiences
                        <span class="pg-load-count">(<%= experiences.length %> of <%= totalExperiences %>)</span>
                    </button>
                </div>
            <% } %>
        <% } %>

        <style>
            .pg-card-animated{opacity:0;transform:translateY(24px);animation:pgFadeIn .5s ease forwards}
            .pg-card-animated:nth-child(1){animation-delay:.05s}.pg-card-animated:nth-child(2){animation-delay:.1s}
            .pg-card-animated:nth-child(3){animation-delay:.15s}.pg-card-animated:nth-child(4){animation-delay:.2s}
            .pg-card-animated:nth-child(5){animation-delay:.25s}.pg-card-animated:nth-child(6){animation-delay:.3s}
            @keyframes pgFadeIn{to{opacity:1;transform:translateY(0)}}
            .pg-skel{border-radius:16px;overflow:hidden;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.06);border:1px solid #f0f0f0}
            .pg-skel-img{width:100%;height:200px;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:pgShimmer 1.5s ease-in-out infinite}
            .pg-skel-body{padding:1rem}.pg-skel-line{height:14px;border-radius:6px;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:pgShimmer 1.5s ease-in-out infinite;margin-bottom:.6rem}
            .pg-skel-line.w75{width:75%}.pg-skel-line.w50{width:50%}.pg-skel-line.w30{width:30%}
            @keyframes pgShimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
            .pg-load-more-wrap{text-align:center;margin:2rem 0 1rem}
            .pg-load-more-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 2rem;border:2px solid var(--border);border-radius:50px;background:#fff;color:var(--dark);font-family:'Inter',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:all .3s ease}
            .pg-load-more-btn:hover{border-color:var(--brand);color:var(--brand);transform:translateY(-2px);box-shadow:0 6px 20px rgba(254,66,77,.15)}
            .pg-load-more-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
            .pg-load-more-btn i{transition:transform .3s ease}.pg-load-more-btn:hover i{transform:translateY(3px)}
            .pg-load-count{font-size:.78rem;color:var(--muted);font-weight:500}
            .pg-load-more-btn.loading i{animation:pgSpin .8s linear infinite}
            @keyframes pgSpin{to{transform:rotate(360deg)}}
        </style>

        <script>
            const expPerPage = <%= perPage %>;
            const totalExp = <%= totalExperiences %>;
            const expSearchQ = '<%= typeof searchQuery !== "undefined" ? searchQuery : "" %>';
            const expCategory = '<%= activeCategory %>';
            let expPage = 1;
            let expLoading = false;

            function optimizeImgUrl(url, w, h) {
                w = w || 800; h = h || 450;
                if (!url) return url;
                if (url.includes('res.cloudinary.com') && url.includes('/upload/')) {
                    return url.replace('/upload/', '/upload/w_' + w + ',h_' + h + ',c_fill,g_auto,q_auto:best,f_auto/');
                }
                return url;
            }

            function createSkeleton() {
                return '<div class="pg-skel"><div class="pg-skel-img"></div><div class="pg-skel-body"><div class="pg-skel-line w75"></div><div class="pg-skel-line w50"></div><div class="pg-skel-line w30"></div></div></div>';
            }

            function getDiffBadge(diff) {
                const d = (diff || 'Easy');
                const bg = d === 'Easy' ? '#ecfdf5' : d === 'Moderate' ? '#fff7ed' : d === 'Challenging' ? '#fef2f2' : '#faf5ff';
                const fg = d === 'Easy' ? '#059669' : d === 'Moderate' ? '#d97706' : d === 'Challenging' ? '#dc2626' : '#7c3aed';
                return `<span style="position:absolute; top:0.6rem; right:0.6rem; font-size:0.7rem; font-weight:700;
                    text-transform:uppercase; letter-spacing:0.5px; padding:0.2rem 0.65rem; border-radius:50px;
                    background:${bg}; color:${fg};">${d}</span>`;
            }

            async function loadMoreExperiences() {
                if (expLoading) return;
                expLoading = true;
                const btn = document.getElementById('exp-load-more');
                btn.classList.add('loading');
                btn.querySelector('i').className = 'fa-solid fa-spinner';
                btn.disabled = true;

                const grid = document.getElementById('exp-grid');
                const skelWrap = document.createElement('div');
                skelWrap.style.display = 'contents';
                for (let i = 0; i < Math.min(expPerPage, 3); i++) {
                    const d = document.createElement('div'); d.style.display = 'contents';
                    d.innerHTML = createSkeleton(); skelWrap.appendChild(d);
                }
                grid.appendChild(skelWrap);
                await new Promise(r => setTimeout(r, 600));

                try {
                    const nextPage = expPage + 1;
                    let url = '/experiences/api/paginate?page=' + nextPage;
                    if (expSearchQ) url += '&search=' + encodeURIComponent(expSearchQ);
                    if (expCategory) url += '&category=' + encodeURIComponent(expCategory);
                    const res = await fetch(url);
                    const data = await res.json();
                    if (skelWrap.parentNode) skelWrap.parentNode.removeChild(skelWrap);

                    data.items.forEach((item, i) => {
                        const imgUrl = (item.images && item.images.length > 0 && item.images[0].url)
                            ? optimizeImgUrl(item.images[0].url) : '/images/default-experience.png';
                        const price = Number(item.price).toLocaleString('en-IN');
                        const destName = item.destination ? item.destination.name + ', ' + item.destination.country : '';
                        const html = `<a href="/experiences/${item._id}?from=experiences" class="cardLink pg-card-animated" style="animation-delay:${i*0.08}s;">
                            <div class="card">
                                <div style="overflow:hidden; position:relative;">
                                    <img src="${imgUrl}" class="card-img-top" alt="${item.title}" onerror="this.onerror=null; this.src='/images/default-experience.png';">
                                    ${getDiffBadge(item.difficulty)}
                                </div>
                                <div class="card-body">
                                    <div class="card-title-text">${item.title}</div>
                                    <div class="card-location">${destName ? '<i class="fa-solid fa-location-dot me-1" style="color:var(--brand);font-size:0.75rem;"></i>' + destName : ''}</div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.4rem;">
                                        <div class="card-price">&#8377; ${price}<span>/person</span></div>
                                        <span style="font-size:0.75rem; color:var(--muted);"><i class="fa-regular fa-clock me-1"></i>${item.duration}</span>
                                    </div>
                                </div>
                            </div>
                        </a>`;
                        const t = document.createElement('div'); t.innerHTML = html;
                        grid.appendChild(t.firstElementChild);
                    });

                    expPage = nextPage;
                    const loaded = Math.min(expPage * expPerPage, totalExp);
                    btn.querySelector('.pg-load-count').textContent = '(' + loaded + ' of ' + totalExp + ')';

                    if (!data.hasMore) {
                        document.getElementById('exp-load-more-wrap').style.display = 'none';
                    } else {
                        btn.classList.remove('loading');
                        btn.querySelector('i').className = 'fa-solid fa-chevron-down';
                        btn.disabled = false;
                    }
                } catch(e) {
                    console.error(e);
                    if (skelWrap.parentNode) skelWrap.parentNode.removeChild(skelWrap);
                    btn.classList.remove('loading');
                    btn.querySelector('i').className = 'fa-solid fa-chevron-down';
                    btn.disabled = false;
                }
                expLoading = false;
            }
        </script>
    </body>
