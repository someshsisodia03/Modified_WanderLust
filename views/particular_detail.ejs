<% layout('boilerplate') -%>

    <body>
        <div class="detail-wrapper">

            <!-- Listing Image -->
            <div style="width:100%; overflow:hidden; border-radius:var(--radius); background:#1e293b; box-shadow:var(--shadow-md);">
                <img src="<%=optimizeImg(details.image.url, 1600, 900)%>" class="detail-img" alt="<%=details.title%>"
                     style="width:100%; aspect-ratio:16/9; height:auto; object-fit:cover; object-position:center; border-radius:0; box-shadow:none; display:block;">
            </div>

            <!-- Main Info Card -->
            <div class="detail-card">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <div class="detail-title">
                            <%=details.title%>
                        </div>
                        <div class="detail-meta">
                            <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);"></i>
                            <%=details.location%>, <%=details.country%>
                                    &nbsp;·&nbsp; Posted by <strong>
                                        <%= details.owner ? details.owner.username : 'WanderLust' %>
                                    </strong>
                        </div>
                    </div>
                    <div style="font-size:1.6rem; font-weight:800; color:var(--brand);">
                        &#8377; <%=details.price.toLocaleString("en-IN")%>
                            <span style="font-size:0.9rem; font-weight:400; color:var(--muted);">/night</span>
                    </div>
                </div>

                <p class="detail-desc mt-3">
                    <%=details.description%>
                </p>

                <div class="detail-info-grid">
                    <div class="detail-info-item"><strong>Location</strong>
                        <%=details.location%>
                    </div>
                    <div class="detail-info-item"><strong>Country</strong>
                        <%=details.country%>
                    </div>
                    <% if(details.category){ %>
                        <div class="detail-info-item"><strong>Category</strong>
                            <%=details.category%>
                        </div>
                        <% } %>
                            <div class="detail-info-item"><strong>Price/night</strong>&#8377;
                                <%=details.price.toLocaleString("en-IN")%>
                            </div>
                </div>

                <!-- Owner Actions -->
                <% if(curruser && details.owner && curruser._id.equals(details.owner._id)){ %>
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <a href="/listing/edit/<%=details.id%>" class="btn-wl-outline" style="text-decoration:none;">
                            <i class="fa-solid fa-pen"></i> Edit Listing
                        </a>
                        <form method="post" action="/deleteDetail/<%=details.id%>?_method=DELETE&from=<%= from %>&destId=<%= destId %>" style="margin:0;">
                            <button class="btn-wl" type="submit"
                                style="background:linear-gradient(135deg,#dc2626,#ef4444);">
                                <i class="fa-solid fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                    <% } %>
            </div>

            <!-- Leave a Review -->
            <% if(curruser){ %>
                <div class="detail-card mt-3">
                    <div class="section-title"><i class="fa-solid fa-star" style="color:var(--brand);"></i> Leave a
                        Review</div>
                    <form class="needs-validation" method="post" action="/listing/<%=details.id%>/review" novalidate>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Your Comment</label>
                            <textarea class="form-control" name="comment" id="comment"
                                placeholder="Share your experience at this place…" rows="4" required></textarea>
                            <div class="invalid-feedback">Please write a review before submitting.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <fieldset class="starability-slot">
                                <legend class="visually-hidden">Rating</legend>
                                <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked
                                    aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="rating" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="rating" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="rating" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="rating" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="rating" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <button type="submit" class="btn-wl"><i class="fa-solid fa-paper-plane"></i> Submit
                            Review</button>
                    </form>
                </div>
                <% } %>

                    <!-- Reviews List -->
                    <% if(details.reviews.length> 0){ %>
                        <div class="detail-card mt-3">
                            <div class="section-title"><i class="fa-solid fa-comments" style="color:var(--brand);"></i>
                                Reviews (<%=details.reviews.length%>)</div>
                            <div class="row g-3">
                                <% for(let x of details.reviews){ %>
                                    <div class="col-md-6">
                                        <div class="review-card">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="review-author"><i class="fa-solid fa-user-circle me-1"
                                                        style="color:var(--brand);"></i>
                                                    <%=x.author.username%>
                                                </div>
                                                <% if(curruser && curruser._id.equals(x.author._id)){ %>
                                                    <form method="post"
                                                        action="/delete/<%=details.id%>/review/<%=x.id%>"
                                                        style="margin:0;">
                                                        <button class="btn-review-delete"><i
                                                                class="fa-solid fa-trash me-1"></i>Delete</button>
                                                    </form>
                                                    <% } %>
                                            </div>
                                            <p class="starability-result" data-rating="<%=x.rating%>"></p>
                                            <p class="review-comment">"<%=x.comment%>"</p>
                                            <% if(x.createdAt){ %>
                                                <small style="color:var(--muted); font-size:0.75rem;">
                                                    <i class="fa-regular fa-clock me-1"></i>
                                                    <%= new Date(x.createdAt).toLocaleDateString('en-IN',
                                                        {day:'numeric',month:'short',year:'numeric'}) %>
                                                </small>
                                                <% } %>
                                        </div>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <% } %>

                            <!-- Map -->
                            <div class="detail-card mt-3">
                                <div class="section-title">
                                    <i class="fa-solid fa-map-location-dot" style="color:var(--brand);"></i>
                                    Location on Map
                                </div>
                                <div id="map-loading"
                                    style="height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f9fafb;border-radius:12px;gap:0.75rem;color:#6b7280;">
                                    <i class="fa-solid fa-spinner fa-spin" style="font-size:2rem;color:#fe424d;"></i>
                                    <span style="font-size:0.9rem;font-weight:500;">Loading map…</span>
                                </div>
                                <div class="map-wrapper" id="map-wrapper" style="display:none;">
                                    <div id="map"></div>
                                </div>
                                <div id="map-error"
                                    style="display:none;padding:1rem;background:#fff1f2;border-radius:12px;color:#b91c1c;font-size:0.9rem;text-align:center;">
                                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                    Could not find map location for <strong>
                                        <%=details.location%>, <%=details.country%>
                                    </strong>.
                                </div>
                            </div>


                            <!-- ── Similar Places You'll Love ── -->
                            <div class="detail-card mt-3" id="rec-section" style="display:none;">
                                <div class="section-title">
                                    <i class="fa-solid fa-wand-magic-sparkles" style="color:var(--brand);"></i>
                                    Similar Places You'll Love
                                    <span style="font-size:0.7rem; font-weight:500; color:var(--muted); margin-left:0.5rem; background:#f3f4f6; padding:0.15rem 0.6rem; border-radius:50px;">
                                        <i class="fa-solid fa-microchip me-1"></i>AI Powered
                                    </span>
                                </div>
                                <div id="rec-loading" style="display:flex; gap:1rem; overflow:hidden;">
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite;"></div>
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; animation-delay:0.2s;"></div>
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; animation-delay:0.4s;"></div>
                                </div>
                                <div id="rec-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem;"></div>
                            </div>

                            <style>
                                @keyframes recShimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
                                .rec-card { border-radius:14px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.07); transition:all 0.3s ease; text-decoration:none; color:inherit; display:block; background:white; border:1px solid #f0f0f0; }
                                .rec-card:hover { transform:translateY(-4px); box-shadow:0 8px 28px rgba(0,0,0,0.12); }
                                .rec-card img { width:100%; aspect-ratio:16/10; object-fit:cover; display:block; }
                                .rec-card-body { padding:0.75rem 0.85rem 0.85rem; }
                                .rec-card-title { font-weight:700; font-size:0.88rem; color:#1a1a2e; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
                                .rec-card-loc { font-size:0.78rem; color:#6b7280; margin-top:0.1rem; }
                                .rec-card-bottom { display:flex; justify-content:space-between; align-items:center; margin-top:0.35rem; }
                                .rec-card-price { font-weight:700; font-size:0.85rem; color:#374151; }
                                .rec-card-price span { font-weight:400; color:#9ca3af; font-size:0.75rem; }
                                .rec-card-score { font-size:0.65rem; font-weight:600; color:#059669; background:#ecfdf5; padding:0.1rem 0.45rem; border-radius:50px; }
                            </style>

        </div><!-- end detail-wrapper -->

        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function () {
                var loc = <%-JSON.stringify((details.location || '').toString()) %>;
                var country = <%-JSON.stringify((details.country || '').toString()) %>;
                var title = <%-JSON.stringify((details.title || '').toString()) %>;

                var loadingEl = document.getElementById('map-loading');
                var wrapperEl = document.getElementById('map-wrapper');
                var errorEl = document.getElementById('map-error');

                var query = encodeURIComponent(loc + ', ' + country);
                var geoUrl = '/api/geocode?q=' + query;

                var timer = setTimeout(function () {
                    loadingEl.style.display = 'none';
                    errorEl.style.display = 'block';
                }, 8000);

                fetch(geoUrl, { headers: { 'Accept-Language': 'en' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        clearTimeout(timer);
                        loadingEl.style.display = 'none';

                        if (!data || data.length === 0) {
                            errorEl.style.display = 'block';
                            return;
                        }

                        var mapLat = parseFloat(data[0].lat);
                        var mapLon = parseFloat(data[0].lon);

                        wrapperEl.style.display = 'block';

                        var map = L.map('map', { scrollWheelZoom: false }).setView([mapLat, mapLon], 12);
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
                            maxZoom: 19
                        }).addTo(map);

                        var pin = L.divIcon({
                            html: '<div style="width:22px;height:22px;background:#fe424d;border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.4);"></div>',
                            iconSize: [22, 22],
                            iconAnchor: [11, 11],
                            popupAnchor: [0, -16],
                            className: ''
                        });
                        L.marker([mapLat, mapLon], { icon: pin }).addTo(map)
                            .bindPopup('<b>' + title + '</b><br><small>' + loc + ', ' + country + '</small>')
                            .openPopup();

                        setTimeout(function () { map.invalidateSize(); }, 300);
                    })
                    .catch(function () {
                        clearTimeout(timer);
                        loadingEl.style.display = 'none';
                        errorEl.style.display = 'block';
                    });
            })();
        </script>

        <!-- ── Recommendations Script ── -->
        <script>
            (function() {
                var listingId = '<%= details.id %>';
                var section = document.getElementById('rec-section');
                var loading = document.getElementById('rec-loading');
                var grid = document.getElementById('rec-grid');

                fetch('/api/recommendations/listing/' + listingId)
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        section.style.display = 'block';
                        loading.style.display = 'none';

                        if (!data.recommendations || data.recommendations.length === 0) {
                            grid.innerHTML = '<div style="text-align:center; padding:2rem 1rem; color:#9ca3af;">' +
                                '<i class="fa-solid fa-compass" style="font-size:2rem; margin-bottom:0.75rem; display:block; color:#d1d5db;"></i>' +
                                '<p style="font-size:0.95rem; font-weight:600; color:#6b7280; margin:0;">No similar places found</p>' +
                                '<p style="font-size:0.8rem; margin:0.25rem 0 0;">This place is unique! We couldn\'t find close matches above 75% similarity.</p>' +
                                '</div>';
                            return;
                        }

                        data.recommendations.forEach(function(rec) {
                            var imgUrl = rec.image && rec.image.url ? rec.image.url : '';
                            if (imgUrl && imgUrl.includes('res.cloudinary.com') && imgUrl.includes('/upload/')) {
                                imgUrl = imgUrl.replace('/upload/', '/upload/w_500,h_320,c_fill,g_auto,q_auto:best,f_auto/');
                            }
                            var price = Number(rec.price).toLocaleString('en-IN');
                            var card = document.createElement('a');
                            card.href = '/moreabout/' + rec._id + '?from=stays';
                            card.className = 'rec-card';
                            card.innerHTML = '<img src="' + imgUrl + '" alt="' + rec.title + '">' +
                                '<div class="rec-card-body">' +
                                    '<div class="rec-card-title">' + rec.title + '</div>' +
                                    '<div class="rec-card-loc"><i class="fa-solid fa-location-dot me-1" style="color:#fe424d;font-size:0.65rem;"></i>' + rec.location + ', ' + rec.country + '</div>' +
                                    '<div class="rec-card-bottom">' +
                                        '<div class="rec-card-price">&#8377; ' + price + ' <span>/night</span></div>' +
                                        '<span class="rec-card-score">' + rec.similarityScore + '% match</span>' +
                                    '</div>' +
                                '</div>';
                            grid.appendChild(card);
                        });
                    })
                    .catch(function(err) {
                        section.style.display = 'block';
                        loading.style.display = 'none';
                        grid.innerHTML = '<div style="text-align:center; padding:2rem 1rem; color:#9ca3af;">' +
                            '<i class="fa-solid fa-compass" style="font-size:2rem; margin-bottom:0.75rem; display:block; color:#d1d5db;"></i>' +
                            '<p style="font-size:0.95rem; font-weight:600; color:#6b7280; margin:0;">No similar places found</p>' +
                            '</div>';
                    });
            })();
        </script>
    </body>
