<% layout('boilerplate') -%>

    <body>
        <div class="detail-wrapper">

            <!-- Listing Image -->
            <div style="width:100%; overflow:hidden; border-radius:var(--radius); background:#1e293b; box-shadow:var(--shadow-md);">
                <img src="<%=optimizeImg(details.image.url, 1600, 900)%>" class="detail-img" alt="<%=details.title%>"
                     style="width:100%; aspect-ratio:16/9; height:auto; object-fit:cover; object-position:center; border-radius:0; box-shadow:none; display:block;">
            </div>

            <!-- Main Info Card -->
            <div class="detail-card">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <div class="detail-title">
                            <%=details.title%>
                        </div>
                        <div class="detail-meta">
                            <i class="fa-solid fa-location-dot me-1" style="color:var(--brand);"></i>
                            <%=details.location%>, <%=details.country%>
                                    &nbsp;·&nbsp; Posted by <strong>
                                        <%= details.owner ? details.owner.username : 'WanderLust' %>
                                    </strong>
                        </div>
                    </div>
                    <div style="font-size:1.6rem; font-weight:800; color:var(--brand);">
                        &#8377; <%=details.price.toLocaleString("en-IN")%>
                            <span style="font-size:0.9rem; font-weight:400; color:var(--muted);">/night</span>
                    </div>
                </div>

                <p class="detail-desc mt-3">
                    <%=details.description%>
                </p>

                <div class="detail-info-grid">
                    <div class="detail-info-item"><strong>Location</strong>
                        <%=details.location%>
                    </div>
                    <div class="detail-info-item"><strong>Country</strong>
                        <%=details.country%>
                    </div>
                    <% if(details.category){ %>
                        <div class="detail-info-item"><strong>Category</strong>
                            <%=details.category%>
                        </div>
                        <% } %>
                            <div class="detail-info-item"><strong>Price/night</strong>&#8377;
                                <%=details.price.toLocaleString("en-IN")%>
                            </div>
                </div>

                <!-- Owner Actions -->
                <% if(curruser && details.owner && curruser._id.equals(details.owner._id)){ %>
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <a href="/listing/edit/<%=details.id%>" class="btn-wl-outline" style="text-decoration:none;">
                            <i class="fa-solid fa-pen"></i> Edit Listing
                        </a>
                        <form method="post" action="/deleteDetail/<%=details.id%>?_method=DELETE&from=<%= from %>&destId=<%= destId %>" style="margin:0;">
                            <button class="btn-wl" type="submit"
                                style="background:linear-gradient(135deg,#dc2626,#ef4444);">
                                <i class="fa-solid fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                    <% } %>
            </div>

            <!-- Leave a Review -->
            <% if(curruser){ %>
                <div class="detail-card mt-3">
                    <div class="section-title"><i class="fa-solid fa-comment-dots" style="color:var(--brand);"></i> Leave a
                        Review</div>
                    <form class="needs-validation" method="post" action="/listing/<%=details.id%>/review" novalidate>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Your Comment</label>
                            <textarea class="form-control" name="comment" id="comment"
                                placeholder="Share your experience at this place…" rows="4" required></textarea>
                            <div class="invalid-feedback">Please write a review before submitting.</div>
                        </div>

                        <button type="submit" class="btn-wl"><i class="fa-solid fa-paper-plane"></i> Submit
                            Review</button>
                    </form>
                </div>
                <% } %>

                    <!-- Reviews List -->
                    <% if(details.reviews.length> 0){ %>
                        <div class="detail-card mt-3">
                            <div class="section-title"><i class="fa-solid fa-comments" style="color:var(--brand);"></i>
                                Reviews (<%=details.reviews.length%>)</div>
                            <div class="row g-3">
                                <% for(let x of details.reviews){ %>
                                    <div class="col-md-6">
                                        <div class="review-card">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="review-author"><i class="fa-solid fa-user-circle me-1"
                                                        style="color:var(--brand);"></i>
                                                    <%=x.author.username%>
                                                </div>
                                                <% if(curruser && curruser._id.equals(x.author._id)){ %>
                                                    <form method="post"
                                                        action="/delete/<%=details.id%>/review/<%=x.id%>"
                                                        style="margin:0;">
                                                        <button class="btn-review-delete"><i
                                                                class="fa-solid fa-trash me-1"></i>Delete</button>
                                                    </form>
                                                    <% } %>
                                            </div>

                                            <p class="review-comment">"<%=x.comment%>"</p>
                                            <% if(x.createdAt){ %>
                                                <small style="color:var(--muted); font-size:0.75rem;">
                                                    <i class="fa-regular fa-clock me-1"></i>
                                                    <%= new Date(x.createdAt).toLocaleDateString('en-IN',
                                                        {day:'numeric',month:'short',year:'numeric'}) %>
                                                </small>
                                                <% } %>
                                        </div>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <% } %>

                            <!-- ── AI Sentiment Analysis Card ── -->
                            <div class="detail-card mt-3" id="sentiment-section" style="display:none;">
                                <div class="section-title">
                                    <i class="fa-solid fa-brain" style="color:var(--brand);"></i>
                                    Sentiment Analysis
                                    <span id="sentiment-badge" style="margin-left:0.6rem; font-size:0.72rem; font-weight:600; padding:0.2rem 0.65rem; border-radius:50px; vertical-align:middle;"></span>
                                </div>

                                <!-- Skeleton loader -->
                                <div id="sentiment-loading">
                                    <div style="display:flex; gap:1.5rem; flex-wrap:wrap; align-items:center;">
                                        <div style="width:90px; height:90px; border-radius:50%; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite;"></div>
                                        <div style="flex:1; min-width:180px;">
                                            <div style="height:12px; border-radius:6px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; margin-bottom:0.6rem;"></div>
                                            <div style="height:12px; border-radius:6px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; margin-bottom:0.6rem; width:80%;"></div>
                                            <div style="height:12px; border-radius:6px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; width:60%;"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Actual content (hidden until loaded) -->
                                <div id="sentiment-content" style="display:none;">

                                    <!-- Row 1: Score gauge + breakdown -->
                                    <div style="display:flex; gap:1.5rem; flex-wrap:wrap; align-items:flex-start; margin-bottom:1.2rem;">

                                        <!-- Circular score gauge -->
                                        <div style="text-align:center; min-width:100px;">
                                            <div style="position:relative; width:90px; height:90px; margin:0 auto;">
                                                <svg width="90" height="90" viewBox="0 0 90 90">
                                                    <circle cx="45" cy="45" r="38" fill="none" stroke="#f0f0f0" stroke-width="8"/>
                                                    <circle id="sent-gauge-ring" cx="45" cy="45" r="38" fill="none" stroke="#22c55e" stroke-width="8"
                                                        stroke-linecap="round"
                                                        stroke-dasharray="239"
                                                        stroke-dashoffset="239"
                                                        transform="rotate(-90 45 45)"
                                                        style="transition: stroke-dashoffset 1s ease, stroke 0.5s ease;"/>
                                                </svg>
                                                <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;">
                                                    <span id="sent-score-text" style="font-size:1.4rem; font-weight:800; color:#1a1a2e; line-height:1;">-</span>
                                                    <span style="font-size:0.6rem; color:#6b7280; font-weight:500;">/ 5</span>
                                                </div>
                                            </div>
                                            <div id="sent-label-text" style="font-size:0.75rem; font-weight:600; margin-top:0.4rem; color:#374151;"></div>
                                            <div id="sent-review-count" style="font-size:0.68rem; color:#9ca3af; margin-top:0.1rem;"></div>
                                        </div>

                                        <!-- Breakdown bars -->
                                        <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.6rem; justify-content:center;">
                                            <div>
                                                <div style="display:flex; justify-content:space-between; font-size:0.75rem; font-weight:600; color:#374151; margin-bottom:3px;">
                                                    <span>😊 Positive</span><span id="pct-pos">0%</span>
                                                </div>
                                                <div style="background:#f0fdf4; border-radius:50px; height:8px; overflow:hidden;">
                                                    <div id="bar-pos" style="height:100%; border-radius:50px; background:linear-gradient(90deg,#22c55e,#4ade80); width:0%; transition:width 1s ease;"></div>
                                                </div>
                                            </div>
                                            <div>
                                                <div style="display:flex; justify-content:space-between; font-size:0.75rem; font-weight:600; color:#374151; margin-bottom:3px;">
                                                    <span>😐 Neutral</span><span id="pct-neu">0%</span>
                                                </div>
                                                <div style="background:#fefce8; border-radius:50px; height:8px; overflow:hidden;">
                                                    <div id="bar-neu" style="height:100%; border-radius:50px; background:linear-gradient(90deg,#eab308,#fbbf24); width:0%; transition:width 1s ease 0.1s;"></div>
                                                </div>
                                            </div>
                                            <div>
                                                <div style="display:flex; justify-content:space-between; font-size:0.75rem; font-weight:600; color:#374151; margin-bottom:3px;">
                                                    <span>😞 Negative</span><span id="pct-neg">0%</span>
                                                </div>
                                                <div style="background:#fff1f2; border-radius:50px; height:8px; overflow:hidden;">
                                                    <div id="bar-neg" style="height:100%; border-radius:50px; background:linear-gradient(90deg,#ef4444,#f87171); width:0%; transition:width 1s ease 0.2s;"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Row 2: Top themes -->
                                    <div id="themes-row" style="margin-bottom:1rem; display:none;">
                                        <div style="font-size:0.78rem; font-weight:600; color:#374151; margin-bottom:0.5rem;">
                                            <i class="fa-solid fa-tags me-1" style="color:var(--brand);"></i> Top Themes
                                        </div>
                                        <div id="themes-container" style="display:flex; flex-wrap:wrap; gap:0.4rem;"></div>
                                    </div>

                                    <!-- Row 3: AI Summary -->
                                    <div id="ai-summary-row" style="display:none; background:linear-gradient(135deg,#f8faff,#f0f4ff); border-radius:12px; padding:0.9rem 1rem; border-left:3px solid var(--brand);">
                                        <div style="font-size:0.73rem; font-weight:700; color:var(--brand); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">
                                            <i class="fa-solid fa-wand-sparkles me-1"></i> Summary
                                        </div>
                                        <p id="ai-summary-text" style="font-size:0.88rem; color:#374151; margin:0; line-height:1.6; font-style:italic;"></p>
                                    </div>

                                    <!-- No data state -->
                                    <div id="sentiment-empty" style="display:none; text-align:center; padding:1.5rem; color:#9ca3af; font-size:0.85rem;">
                                        <i class="fa-solid fa-chart-pie me-1"></i> Not enough reviews to analyze yet.
                                    </div>
                                </div>
                            </div>

                            <!-- Sentiment Script -->
                            <script>
                            (function() {
                                var listingId = '<%= details.id %>';
                                var section   = document.getElementById('sentiment-section');
                                var loading   = document.getElementById('sentiment-loading');
                                var content   = document.getElementById('sentiment-content');

                                // Only fetch if there are reviews
                                var reviewCount = <%= details.reviews.length %>;
                                if (reviewCount === 0) return;

                                section.style.display = 'block';

                                fetch('/api/sentiment/' + listingId)
                                    .then(function(r) { return r.json(); })
                                    .then(function(d) {
                                        loading.style.display = 'none';
                                        content.style.display  = 'block';

                                        if (!d.analyzed || d.analyzed === 0) {
                                            document.getElementById('sentiment-empty').style.display = 'block';
                                            return;
                                        }

                                        // ── Badge ──
                                        var badge = document.getElementById('sentiment-badge');
                                        var dominant = d.breakdown.positive >= d.breakdown.negative ? 'positive' : 'negative';
                                        if (d.breakdown.positive >= 50) {
                                            badge.textContent = '😊 Mostly Positive';
                                            badge.style.cssText += 'background:#dcfce7; color:#166534;';
                                        } else if (d.breakdown.negative >= 50) {
                                            badge.textContent = '😞 Mostly Negative';
                                            badge.style.cssText += 'background:#fee2e2; color:#991b1b;';
                                        } else {
                                            badge.textContent = '😐 Mixed Reviews';
                                            badge.style.cssText += 'background:#fef9c3; color:#713f12;';
                                        }

                                        // ── Score gauge ──
                                        var score = d.avgScore || 0;
                                        document.getElementById('sent-score-text').textContent = score.toFixed(1);
                                        document.getElementById('sent-review-count').textContent = d.analyzed + ' of ' + d.totalReviews + ' analyzed';

                                        var labelEl = document.getElementById('sent-label-text');
                                        var ring    = document.getElementById('sent-gauge-ring');
                                        var circumference = 239;
                                        var offset = circumference - (score / 5) * circumference;
                                        setTimeout(function() { ring.style.strokeDashoffset = offset; }, 100);

                                        if (score >= 4) {
                                            ring.style.stroke = '#22c55e';
                                            labelEl.textContent = '⭐ Excellent';
                                            labelEl.style.color = '#16a34a';
                                        } else if (score >= 3) {
                                            ring.style.stroke = '#eab308';
                                            labelEl.textContent = '👍 Good';
                                            labelEl.style.color = '#ca8a04';
                                        } else {
                                            ring.style.stroke = '#ef4444';
                                            labelEl.textContent = '👎 Below Average';
                                            labelEl.style.color = '#dc2626';
                                        }

                                        // ── Breakdown bars ──
                                        var b = d.breakdown;
                                        setTimeout(function() {
                                            document.getElementById('bar-pos').style.width = b.positive + '%';
                                            document.getElementById('bar-neu').style.width = b.neutral  + '%';
                                            document.getElementById('bar-neg').style.width = b.negative + '%';
                                        }, 100);
                                        document.getElementById('pct-pos').textContent = b.positive + '%';
                                        document.getElementById('pct-neu').textContent = b.neutral  + '%';
                                        document.getElementById('pct-neg').textContent = b.negative + '%';

                                        // ── Themes ──
                                        if (d.topThemes && d.topThemes.length > 0) {
                                            var row = document.getElementById('themes-row');
                                            var container = document.getElementById('themes-container');
                                            row.style.display = 'block';
                                            d.topThemes.forEach(function(t) {
                                                var chip = document.createElement('span');
                                                var isPos = t.sentiment === 'positive';
                                                chip.textContent = (isPos ? '✅ ' : '⚠️ ') + t.theme;
                                                chip.style.cssText = 'display:inline-block; padding:0.25rem 0.7rem; border-radius:50px; font-size:0.72rem; font-weight:600; cursor:default; ' +
                                                    (isPos ? 'background:#dcfce7; color:#166534; border:1px solid #bbf7d0;' : 'background:#fee2e2; color:#991b1b; border:1px solid #fecaca;');
                                                container.appendChild(chip);
                                            });
                                        }

                                        // ── AI Summary ──
                                        if (d.aiSummary && d.aiSummary.trim().length > 0) {
                                            document.getElementById('ai-summary-row').style.display = 'block';
                                            document.getElementById('ai-summary-text').textContent = d.aiSummary;
                                        }
                                    })
                                    .catch(function() {
                                        loading.style.display = 'none';
                                        content.style.display = 'block';
                                        document.getElementById('sentiment-empty').style.display = 'block';
                                    });
                            })();
                            </script>

                            <!-- Map -->
                            <div class="detail-card mt-3">
                                <div class="section-title">
                                    <i class="fa-solid fa-map-location-dot" style="color:var(--brand);"></i>
                                    Location on Map
                                </div>
                                <div id="map-loading"
                                    style="height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f9fafb;border-radius:12px;gap:0.75rem;color:#6b7280;">
                                    <i class="fa-solid fa-spinner fa-spin" style="font-size:2rem;color:#fe424d;"></i>
                                    <span style="font-size:0.9rem;font-weight:500;">Loading map…</span>
                                </div>
                                <div class="map-wrapper" id="map-wrapper" style="display:none;">
                                    <div id="map"></div>
                                </div>
                                <div id="map-error"
                                    style="display:none;padding:1rem;background:#fff1f2;border-radius:12px;color:#b91c1c;font-size:0.9rem;text-align:center;">
                                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                    Could not find map location for <strong>
                                        <%=details.location%>, <%=details.country%>
                                    </strong>.
                                </div>
                            </div>


                            <!-- ── Similar Places You'll Love ── -->
                            <div class="detail-card mt-3" id="rec-section" style="display:none;">
                                <div class="section-title">
                                    <i class="fa-solid fa-wand-magic-sparkles" style="color:var(--brand);"></i>
                                    Similar Places You'll Love
                                </div>
                                <div id="rec-loading" style="display:flex; gap:1rem; overflow:hidden;">
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite;"></div>
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; animation-delay:0.2s;"></div>
                                    <div style="flex:1; min-width:200px; height:180px; border-radius:14px; background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%); background-size:200% 100%; animation:recShimmer 1.5s ease-in-out infinite; animation-delay:0.4s;"></div>
                                </div>
                                <div id="rec-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem;"></div>
                                <div id="rec-empty" style="display:none; text-align:center; padding:2rem 1rem;">
                                    <div style="width:56px; height:56px; margin:0 auto 0.75rem; background:#f1f5f9; border-radius:50%; display:flex; align-items:center; justify-content:center;">
                                        <i class="fa-regular fa-compass" style="font-size:1.5rem; color:#94a3b8;"></i>
                                    </div>
                                    <p style="color:#6b7280; font-size:0.9rem; margin:0;">No similar places found</p>
                                </div>
                            </div>

                            <style>
                                @keyframes recShimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
                                .rec-card { border-radius:14px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.07); transition:all 0.3s ease; text-decoration:none; color:inherit; display:block; background:white; border:1px solid #f0f0f0; }
                                .rec-card:hover { transform:translateY(-4px); box-shadow:0 8px 28px rgba(0,0,0,0.12); }
                                .rec-card img { width:100%; aspect-ratio:16/10; object-fit:cover; display:block; }
                                .rec-card-body { padding:0.75rem 0.85rem 0.85rem; }
                                .rec-card-title { font-weight:700; font-size:0.88rem; color:#1a1a2e; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
                                .rec-card-loc { font-size:0.78rem; color:#6b7280; margin-top:0.1rem; }
                                .rec-card-bottom { display:flex; justify-content:space-between; align-items:center; margin-top:0.35rem; }
                                .rec-card-price { font-weight:700; font-size:0.85rem; color:#374151; }
                                .rec-card-price span { font-weight:400; color:#9ca3af; font-size:0.75rem; }
                                .rec-card-score { font-size:0.65rem; font-weight:600; color:#059669; background:#ecfdf5; padding:0.1rem 0.45rem; border-radius:50px; }
                            </style>

        </div><!-- end detail-wrapper -->

        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function () {
                var loc = <%-JSON.stringify((details.location || '').toString()) %>;
                var country = <%-JSON.stringify((details.country || '').toString()) %>;
                var title = <%-JSON.stringify((details.title || '').toString()) %>;

                var loadingEl = document.getElementById('map-loading');
                var wrapperEl = document.getElementById('map-wrapper');
                var errorEl = document.getElementById('map-error');

                var query = encodeURIComponent(loc + ', ' + country);
                var geoUrl = '/api/geocode?q=' + query;

                var timer = setTimeout(function () {
                    loadingEl.style.display = 'none';
                    errorEl.style.display = 'block';
                }, 8000);

                fetch(geoUrl, { headers: { 'Accept-Language': 'en' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        clearTimeout(timer);
                        loadingEl.style.display = 'none';

                        if (!data || data.length === 0) {
                            errorEl.style.display = 'block';
                            return;
                        }

                        var mapLat = parseFloat(data[0].lat);
                        var mapLon = parseFloat(data[0].lon);

                        wrapperEl.style.display = 'block';

                        var map = L.map('map', { scrollWheelZoom: false }).setView([mapLat, mapLon], 12);
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
                            maxZoom: 19
                        }).addTo(map);

                        var pin = L.divIcon({
                            html: '<div style="width:22px;height:22px;background:#fe424d;border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.4);"></div>',
                            iconSize: [22, 22],
                            iconAnchor: [11, 11],
                            popupAnchor: [0, -16],
                            className: ''
                        });
                        L.marker([mapLat, mapLon], { icon: pin }).addTo(map)
                            .bindPopup('<b>' + title + '</b><br><small>' + loc + ', ' + country + '</small>')
                            .openPopup();

                        setTimeout(function () { map.invalidateSize(); }, 300);
                    })
                    .catch(function () {
                        clearTimeout(timer);
                        loadingEl.style.display = 'none';
                        errorEl.style.display = 'block';
                    });
            })();
        </script>

        <!-- ── Recommendations Script ── -->
        <script>
            (function() {
                var listingId = '<%= details.id %>';
                var section = document.getElementById('rec-section');
                var loading = document.getElementById('rec-loading');
                var grid = document.getElementById('rec-grid');

                fetch('/api/recommendations/listing/' + listingId)
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        loading.style.display = 'none';

                        if (!data.recommendations || data.recommendations.length === 0) {
                            // No matches — show empty state
                            section.style.display = 'block';
                            document.getElementById('rec-empty').style.display = 'block';
                            return;
                        }

                        // Has results — show the section
                        section.style.display = 'block';

                        data.recommendations.forEach(function(rec) {
                            var imgUrl = rec.image && rec.image.url ? rec.image.url : '';
                            if (imgUrl && imgUrl.includes('res.cloudinary.com') && imgUrl.includes('/upload/')) {
                                imgUrl = imgUrl.replace('/upload/', '/upload/w_500,h_320,c_fill,g_auto,q_auto:best,f_auto/');
                            }
                            var price = Number(rec.price).toLocaleString('en-IN');
                            var card = document.createElement('a');
                            card.href = '/moreabout/' + rec._id + '?from=stays';
                            card.className = 'rec-card';
                            card.innerHTML = '<img src="' + imgUrl + '" alt="' + rec.title + '">' +
                                '<div class="rec-card-body">' +
                                    '<div class="rec-card-title">' + rec.title + '</div>' +
                                    '<div class="rec-card-loc"><i class="fa-solid fa-location-dot me-1" style="color:#fe424d;font-size:0.65rem;"></i>' + rec.location + ', ' + rec.country + '</div>' +
                                    '<div class="rec-card-bottom">' +
                                        '<div class="rec-card-price">&#8377; ' + price + ' <span>/night</span></div>' +
                                        '<span class="rec-card-score">' + rec.similarityScore + '% match</span>' +
                                    '</div>' +
                                '</div>';
                            grid.appendChild(card);
                        });
                    })
                    .catch(function(err) {
                        // On error — show empty state
                        loading.style.display = 'none';
                        section.style.display = 'block';
                        document.getElementById('rec-empty').style.display = 'block';
                    });
            })();
        </script>
    </body>
