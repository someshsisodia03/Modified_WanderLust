<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust &mdash; Discover Your Next Stay</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23fe424d' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polygon points='16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76' fill='%23fe424d'/></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
        integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Design Tokens ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        :root {
            --brand: #fe424d;
            --brand-dark: #d9333d;
            --brand-light: #fff0f1;
            --dark: #1a1a2e;
            --text: #374151;
            --muted: #6b7280;
            --border: #e5e7eb;
            --radius: 14px;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.07);
            --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.10);
            --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.14);
            --transition: 0.25s ease;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Base ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text);
            background: #fafafa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main,
        body>div:not(.wl-footer):not(nav) {
            flex: 1;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Navbar ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .navbar {
            background: rgba(255, 255, 255, 0.92) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border) !important;
            padding: 0.75rem 1.5rem;
            box-shadow: var(--shadow-sm);
            margin-bottom: 0 !important;
        }

        .navbar-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -0.5px;
            color: var(--brand) !important;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .navbar-brand i {
            font-size: 1.3rem;
            color: var(--brand);
        }

        .nav-link {
            font-size: 0.95rem !important;
            font-weight: 500 !important;
            color: var(--text) !important;
            padding: 0.4rem 0.75rem !important;
            border-radius: 8px;
            transition: color 0.3s ease;
        }

        .nav-active {
            color: var(--brand) !important;
            font-weight: 600 !important;
        }

        /* в”Ђв”Ђ Mobile nav dropdown styles в”Ђв”Ђ */
        @media (max-width: 991.98px) {
            #navSlider {
                display: none !important;
            }

            #mainNavLinks .nav-link {
                padding: 0.65rem 0.75rem !important;
                border-radius: 8px;
                background: transparent !important;
            }

            #mainNavLinks .nav-link:hover {
                color: var(--brand) !important;
            }

            #mainNavLinks .nav-link.nav-active {
                color: var(--brand) !important;
                font-weight: 700 !important;
                background: transparent !important;
            }
        }


        .btn-search {
            background: linear-gradient(135deg, var(--brand), #ff6b6b);
            color: white;
            border: none;
            border-radius: 50px !important;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            font-size: 0.9rem;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all var(--transition);
            box-shadow: 0 4px 14px rgba(254, 66, 77, 0.35);
        }

        .btn-search:hover {
            background: linear-gradient(135deg, var(--brand-dark), var(--brand));
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(254, 66, 77, 0.45);
        }

        /* Search form responsive container */
        .search-form {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
            max-width: 520px;
        }

        .srch {
            border-radius: 50px !important;
            border: 1.5px solid var(--border);
            padding: 0.5rem 1.2rem;
            font-size: 0.9rem;
            flex: 1;
            min-width: 0;
            /* allow shrink below content width */
            transition: border var(--transition), box-shadow var(--transition);
        }

        .srch:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(254, 66, 77, 0.1);
            outline: none;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ Navbar search responsive ГўвЂќв‚¬ГўвЂќв‚¬ */
        .navbar-search-wrap {
            flex: 1;
            display: flex;
            justify-content: center;
            padding: 0 1rem;
        }

        .search-tabs-container {
            width: 100%;
            max-width: 540px;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ Search Tabs ГўвЂќв‚¬ГўвЂќв‚¬ */
        .search-tabs {
            display: flex;
            gap: 0.25rem;
            margin-bottom: 0.4rem;
        }

        .search-tab {
            display: flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.3rem 0.75rem;
            border: none;
            background: transparent;
            color: var(--muted);
            font-size: 0.78rem;
            font-weight: 600;
            border-radius: 50px;
            cursor: pointer;
            transition: all var(--transition);
            white-space: nowrap;
        }

        .search-tab i {
            font-size: 0.72rem;
        }

        .search-tab:hover {
            background: var(--brand-light);
            color: var(--brand);
        }

        .search-tab.active {
            background: var(--brand);
            color: white;
            box-shadow: 0 2px 8px rgba(254, 66, 77, 0.25);
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ Search input with icon ГўвЂќв‚¬ГўвЂќв‚¬ */
        .search-input-wrap {
            position: relative;
            flex: 1;
            min-width: 0;
        }

        .search-input-wrap .search-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 0.85rem;
            pointer-events: none;
        }

        .search-input-wrap .srch {
            padding-left: 2.5rem;
        }

        @media (max-width: 991.98px) {
            .navbar-search-wrap {
                padding: 0.5rem 0;
                order: 3;
                width: 100%;
            }

            .search-tabs-container {
                max-width: 100%;
            }

            .search-form {
                max-width: 100%;
                width: 100%;
            }
        }

        @media (max-width: 576px) {
            .btn-search span {
                display: none;
            }

            /* hide text, keep icon */
            .btn-search {
                padding: 0.5rem 0.9rem;
            }

            .search-tab span {
                display: none;
            }

            .search-tab {
                padding: 0.3rem 0.6rem;
            }
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Flash Alerts ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .flash-container {
            position: fixed;
            top: 1.25rem;
            right: 1.25rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            min-width: 280px;
            max-width: 380px;
        }

        .flash-toast {
            border-radius: 12px;
            padding: 0.9rem 1.1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            box-shadow: var(--shadow-md);
            animation: toastIn 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
            font-size: 0.92rem;
            font-weight: 500;
        }

        .flash-toast.success {
            background: #ecfdf5;
            border-left: 4px solid #10b981;
            color: #065f46;
        }

        .flash-toast.danger {
            background: #fff1f2;
            border-left: 4px solid var(--brand);
            color: #9f1239;
        }

        .flash-toast i {
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .flash-toast .btn-close {
            margin-left: auto;
            font-size: 0.75rem;
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateX(30px) scale(0.9);
            }

            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Category Filters ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .filters-wrap {
            position: relative;
            background: white;
            border-bottom: 1px solid var(--border);
            overflow: hidden;
        }

        /* Arrow buttons */
        .filter-arrow {
            display: none;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 3;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 1.5px solid var(--border);
            background: white;
            color: var(--text);
            font-size: 0.8rem;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: all 0.2s ease;
        }

        .filter-arrow:hover {
            background: var(--brand);
            color: white;
            border-color: var(--brand);
            box-shadow: 0 4px 12px rgba(254,66,77,0.3);
        }

        .filter-arrow-left { left: 4px; }
        .filter-arrow-right { right: 4px; }

        .filter-arrow.hidden { opacity: 0; pointer-events: none; }

        @media (max-width: 991.98px) {
            .filter-arrow {
                display: flex;
            }
        }

        .filters {
            display: flex;
            flex-wrap: nowrap;
            overflow-x: auto;
            gap: 0.25rem;
            padding: 1rem 1.5rem 0.5rem;
            background: white;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
            scroll-behavior: smooth;
        }

        @media (max-width: 991.98px) {
            .filters {
                padding: 1rem 40px 0.5rem;
                -webkit-mask-image: linear-gradient(to right, transparent 0px, black 42px, black calc(100% - 42px), transparent 100%);
                mask-image: linear-gradient(to right, transparent 0px, black 42px, black calc(100% - 42px), transparent 100%);
            }
        }

        .filters::-webkit-scrollbar {
            display: none;
        }

        .filter {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.3rem;
            padding: 0.6rem 1.1rem;
            border-radius: 12px;
            cursor: pointer;
            opacity: 0.6;
            transition: all var(--transition);
            white-space: nowrap;
            flex-shrink: 0;
            border-bottom: 2px solid transparent;
        }

        .filter:hover,
        .filter.active {
            opacity: 1;
            border-bottom-color: var(--brand);
        }

        .filter a {
            text-decoration: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.3rem;
        }

        .filter i {
            font-size: 1.4rem;
            color: var(--text);
        }

        .filter:hover i {
            color: var(--brand);
        }

        .icon-text {
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--text);
            margin: 0;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Tax toggle ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .tax-box {
            border: 1.5px solid var(--border);
            padding: 0.6rem 1rem;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            white-space: nowrap;
            font-size: 0.85rem;
            font-weight: 500;
            flex-shrink: 0;
            background: white;
        }

        .tax-info {
            display: none;
        }

        @media (max-width: 991.98px) {
            .tax-box {
                display: none !important;
            }
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Listing Cards ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
            gap: 1.75rem;
            padding: 2rem 2.5rem;
        }

        .cardLink {
            text-decoration: none;
            color: inherit;
            display: block;
            border-radius: var(--radius);
            transition: transform var(--transition);
        }

        .cardLink:hover {
            transform: translateY(-4px);
        }

        .cardLink:hover .card {
            box-shadow: var(--shadow-lg);
        }

        .card {
            border: none !important;
            border-radius: var(--radius) !important;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: box-shadow var(--transition);
            background: white;
        }

        .card-img-top {
            width: 100%;
            aspect-ratio: 16 / 9;
            height: auto;
            object-fit: cover;
            object-position: center;
            border-radius: 0 !important;
            transition: transform 0.4s ease;
            background: #1e293b;
        }

        .cardLink:hover .card-img-top {
            transform: scale(1.03);
        }

        .card-body {
            padding: 1rem 1.1rem 1.1rem;
        }

        .card-title-text {
            font-weight: 700;
            font-size: 1.08rem;
            color: var(--dark);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .card-location {
            font-size: 0.88rem;
            color: var(--muted);
            margin-top: 0.15rem;
        }

        .card-price {
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text);
            margin-top: 0.4rem;
        }

        .card-price span {
            font-weight: 400;
            color: var(--muted);
            font-size: 0.85rem;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Forms ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .forms {
            display: flex;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .wl-form-card {
            background: white;
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            padding: 2.5rem 2.5rem;
            width: 100%;
            max-width: 580px;
        }

        .wl-form-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 0.25rem;
        }

        .wl-form-subtitle {
            font-size: 0.9rem;
            color: var(--muted);
            margin-bottom: 1.75rem;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--text);
            margin-bottom: 0.3rem;
        }

        .form-control,
        .form-select {
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 0.6rem 0.9rem;
            font-size: 0.92rem;
            transition: border var(--transition), box-shadow var(--transition);
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(254, 66, 77, 0.1);
            outline: none;
        }

        .btn-wl {
            background: linear-gradient(135deg, var(--brand), #ff6b6b);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 0.65rem 2rem;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all var(--transition);
            box-shadow: 0 4px 16px rgba(254, 66, 77, 0.35);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-wl:hover {
            background: linear-gradient(135deg, var(--brand-dark), var(--brand));
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(254, 66, 77, 0.45);
            color: white;
        }

        .btn-wl-outline {
            background: transparent;
            color: var(--brand);
            border: 2px solid var(--brand);
            border-radius: 50px;
            padding: 0.55rem 1.6rem;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all var(--transition);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .btn-wl-outline:hover {
            background: var(--brand);
            color: white;
            transform: translateY(-2px);
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Detail page ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .detail-wrapper {
            max-width: 860px;
            margin: 2rem auto;
            padding: 0 1.25rem;
        }

        .detail-img {
            display: block;
            width: 100%;
            min-width: 100%;
            aspect-ratio: 16 / 9;
            height: auto;
            object-fit: cover;
            object-position: center;
            border-radius: var(--radius);
            box-shadow: var(--shadow-md);
            background: #1e293b;
        }

        .detail-card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            padding: 1.75rem 2rem;
            margin-top: 1.5rem;
        }

        .detail-title {
            font-size: 1.7rem;
            font-weight: 800;
            color: var(--dark);
        }

        .detail-meta {
            color: var(--muted);
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .detail-desc {
            color: var(--text);
            font-size: 0.97rem;
            line-height: 1.7;
        }

        .detail-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
            margin-top: 1rem;
        }

        .detail-info-item {
            background: #f9fafb;
            border-radius: 10px;
            padding: 0.65rem 0.9rem;
            font-size: 0.88rem;
        }

        .detail-info-item strong {
            color: var(--dark);
            display: block;
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.1rem;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Review cards ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .review-card {
            background: #f9fafb;
            border-radius: 12px;
            padding: 1rem 1.2rem;
            margin-bottom: 0.75rem;
            border: 1px solid var(--border);
        }

        .review-author {
            font-weight: 700;
            font-size: 0.92rem;
            color: var(--dark);
        }

        .review-comment {
            font-size: 0.9rem;
            color: var(--text);
            margin-top: 0.3rem;
            font-style: italic;
        }

        .btn-review-delete {
            background: #fee2e2;
            color: #b91c1c;
            border: none;
            border-radius: 8px;
            padding: 0.3rem 0.8rem;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: background var(--transition);
            margin-top: 0.5rem;
        }

        .btn-review-delete:hover {
            background: #fecaca;
        }

        .details {
            font-family: 'Inter', sans-serif;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Starability ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .starability-result {
            position: relative;
            width: 150px;
            height: 30px;
            background-image: url("data:image/png;base64,");
            font-size: 0.1em;
            color: transparent;
        }

        .starability-result:after {
            content: ' ';
            position: absolute;
            left: 0;
            height: 30px;
            background-image: url("data:image/png;base64,");
            background-position: 0 -30px;
        }

        .starability-result[data-rating="5"]::after {
            width: 150px;
        }

        .starability-result[data-rating="4"]::after {
            width: 120px;
        }

        .starability-result[data-rating="3"]::after {
            width: 90px;
        }

        .starability-result[data-rating="2"]::after {
            width: 60px;
        }

        .starability-result[data-rating="1"]::after {
            width: 30px;
        }

        .starability-slot {
            display: block;
            position: relative;
            width: 150px;
            min-height: 60px;
            padding: 0;
            border: none;
        }

        .starability-slot>input {
            position: absolute;
            margin-right: -100%;
            opacity: 0;
        }

        .starability-slot>input:checked~label,
        .starability-slot>input:focus~label {
            background-position: 0 0;
        }

        .starability-slot>input:checked+label,
        .starability-slot>input:focus+label {
            background-position: 0 -30px;
        }

        .starability-slot>input[disabled]:hover+label {
            cursor: default;
        }

        .starability-slot>input:not([disabled]):hover~label {
            background-position: 0 0;
        }

        .starability-slot>input:not([disabled]):hover+label {
            background-position: 0 -30px;
        }

        .starability-slot>input:not([disabled]):hover+label::before {
            opacity: 1;
        }

        .starability-slot>input:focus+label {
            outline: 1px dotted #999;
        }

        .starability-slot .starability-focus-ring {
            position: absolute;
            left: 0;
            width: 100%;
            height: 30px;
            outline: 2px dotted #999;
            pointer-events: none;
            opacity: 0;
        }

        .starability-slot>.input-no-rate:focus~.starability-focus-ring {
            opacity: 1;
        }

        .starability-slot>label {
            position: relative;
            display: inline-block;
            float: left;
            width: 30px;
            height: 30px;
            font-size: 0.1em;
            color: transparent;
            cursor: pointer;
            background-image: url("data:image/png;base64,");
            background-repeat: no-repeat;
            background-position: 0 -30px;
        }

        .starability-slot>label::before {
            content: '';
            position: absolute;
            display: block;
            height: 30px;
            background-image: url("data:image/png;base64,");
            background-position: 0 30px;
            pointer-events: none;
            opacity: 0;
        }

        .starability-slot>label:nth-of-type(5)::before {
            width: 120px;
            left: -120px;
        }

        .starability-slot>label:nth-of-type(4)::before {
            width: 90px;
            left: -90px;
        }

        .starability-slot>label:nth-of-type(3)::before {
            width: 60px;
            left: -60px;
        }

        .starability-slot>label:nth-of-type(2)::before {
            width: 30px;
            left: -30px;
        }

        .starability-slot>label:nth-of-type(1)::before {
            width: 0;
            left: 0;
        }

        .starability-slot>input:checked~label,
        .starability-slot>input:hover~label,
        .starability-slot>input:focus~label {
            transition: background-position .7s;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Map ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .map-wrapper {
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        #map {
            width: 100%;
            height: 400px;
        }

        /* ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Section title ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ */
        .section-title {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--dark);
            margin: 1.5rem 0 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }
    </style>
</head>

